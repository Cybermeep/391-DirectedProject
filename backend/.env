# Network Configuration
NIDS_INTERFACE=eth0
NIDS_PROMISCUOUS=false

# Buffer Settings
RING_BUFFER_SIZE=10000

# Flow Settings
FLOW_TIMEOUT=60
MAX_FLOW_SIZE=1000

# Database
DATABASE_URL=sqlite:///../data/alerts.db

# API Settings
API_HOST=0.0.0.0
API_PORT=5000
SECRET_KEY=your-secret-key-here

# ML Model
MODEL_PATH=./src/ml_pipeline/models/random_forest.joblib
SCALER_PATH=./src/ml_pipeline/models/scaler.joblib

# Logging
LOG_LEVEL=INFO